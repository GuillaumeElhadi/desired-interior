# fal.ai API key — required for ML inference (background removal, depth, harmonization)
# Get a key at https://fal.ai
FAL_KEY=

# PostHog public write key — required for opt-in anonymous telemetry
# Create a free project at https://posthog.com and paste the Project API key here.
# This is a public key (safe to commit to .env.example); never put your personal/secret keys here.
VITE_POSTHOG_KEY=
