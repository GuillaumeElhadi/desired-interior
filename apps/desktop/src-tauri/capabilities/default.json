{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "interior-vision-api", "sidecar": true }]
    },
    "shell:allow-kill",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "sql:allow-load"
  ]
}
