{
  "default": {
    "identifier": "default",
    "description": "Default capability for the main window",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      {
        "identifier": "shell:allow-execute",
        "allow": [{ "name": "interior-vision-api", "sidecar": true }]
      },
      "shell:allow-kill",
      "sql:allow-execute",
      "sql:allow-select",
      "sql:allow-close",
      "sql:allow-load",
      "store:allow-load",
      "store:allow-get",
      "store:allow-set",
      "store:allow-save",
      "store:allow-has",
      "store:allow-delete",
      "store:allow-keys"
    ]
  }
}
