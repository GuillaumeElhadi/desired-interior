  "components": {
    "schemas": {
      "Body_extract_objects_extract_post": {
        "properties": {
          "image": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "Image",
            "description": "Object photo (JPEG / PNG / WEBP)"
          }
        },
        "type": "object",
        "required": ["image"],
        "title": "Body_extract_objects_extract_post"
      },
      "Body_preprocess_scenes_preprocess_post": {
        "properties": {
          "image": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "Image",
            "description": "Room photo (JPEG / PNG / WEBP)"
          }
        },
        "type": "object",
        "required": ["image"],
        "title": "Body_preprocess_scenes_preprocess_post"
      },
      "BoundingBox": {
        "properties": {
          "x": {
            "type": "number",
            "title": "X"
          },
          "y": {
            "type": "number",
            "title": "Y"
          },
          "width": {
            "type": "number",
            "title": "Width"
          },
          "height": {
            "type": "number",
            "title": "Height"
          }
        },
        "type": "object",
        "required": ["x", "y", "width", "height"],
        "title": "BoundingBox"
      },
      "ComposeRequest": {
        "properties": {
          "scene_id": {
            "type": "string",
            "title": "Scene Id"
          },
          "object_id": {
            "type": "string",
            "title": "Object Id"
          },
          "placement": {
            "$ref": "#/components/schemas/PlacementSpec"
          },
          "style_hints": {
            "$ref": "#/components/schemas/StyleHints",
            "default": {
              "prompt_suffix": ""
            }
          }
        },
        "type": "object",
        "required": ["scene_id", "object_id", "placement"],
        "title": "ComposeRequest"
      },
      "ComposeResponse": {
        "properties": {
          "composition_id": {
            "type": "string",
            "title": "Composition Id"
          },
          "image": {
            "$ref": "#/components/schemas/ComposedImage"
          }
        },
        "type": "object",
        "required": ["composition_id", "image"],
        "title": "ComposeResponse"
      },
      "ComposedImage": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "content_type": {
            "type": "string",
            "title": "Content Type",
            "default": "image/jpeg"
          }
        },
        "type": "object",
        "required": ["url"],
        "title": "ComposedImage"
      },
      "DepthMap": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "width": {
            "type": "integer",
            "title": "Width"
          },
          "height": {
            "type": "integer",
            "title": "Height"
          }
        },
        "type": "object",
        "required": ["url", "width", "height"],
        "title": "DepthMap"
      },
      "ExtractResponse": {
        "properties": {
          "object_id": {
            "type": "string",
            "title": "Object Id"
          },
          "masked": {
            "$ref": "#/components/schemas/ExtractedObject"
          }
        },
        "type": "object",
        "required": ["object_id", "masked"],
        "title": "ExtractResponse"
      },
      "ExtractedObject": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "width": {
            "type": "integer",
            "title": "Width"
          },
          "height": {
            "type": "integer",
            "title": "Height"
          },
          "content_type": {
            "type": "string",
            "title": "Content Type",
            "default": "image/png"
          }
        },
        "type": "object",
        "required": ["url", "width", "height"],
        "title": "ExtractedObject"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "version": {
            "type": "string",
            "title": "Version"
          }
        },
        "type": "object",
        "required": ["status", "version"],
        "title": "HealthResponse"
      },
      "LogEntry": {
        "properties": {
          "level": {
            "$ref": "#/components/schemas/LogLevel"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "correlation_id": {
            "type": "string",
            "title": "Correlation Id"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          },
          "context": {
            "additionalProperties": true,
            "type": "object",
            "title": "Context",
            "default": {}
          }
        },
        "type": "object",
        "required": ["level", "message", "correlation_id", "timestamp"],
        "title": "LogEntry"
      },
      "LogLevel": {
        "type": "string",
        "enum": ["debug", "info", "warn", "error"],
        "title": "LogLevel"
      },
      "LogRequest": {
        "properties": {
          "entries": {
            "items": {
              "$ref": "#/components/schemas/LogEntry"
            },
            "type": "array",
            "title": "Entries"
          }
        },
        "type": "object",
        "required": ["entries"],
        "title": "LogRequest"
      },
      "MaskResult": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "label": {
            "type": "string",
            "title": "Label",
            "default": ""
          },
          "score": {
            "type": "number",
            "title": "Score",
            "default": 0.0
          },
          "area": {
            "type": "integer",
            "title": "Area",
            "default": 0
          },
          "bbox": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Bbox",
            "default": []
          }
        },
        "type": "object",
        "required": ["url"],
        "title": "MaskResult"
      },
      "PlacementSpec": {
        "properties": {
          "bbox": {
            "$ref": "#/components/schemas/BoundingBox"
          },
          "depth_hint": {
            "type": "number",
            "title": "Depth Hint",
            "default": 0.5
          }
        },
        "type": "object",
        "required": ["bbox"],
        "title": "PlacementSpec"
      },
      "PreprocessResponse": {
        "properties": {
          "scene_id": {
            "type": "string",
            "title": "Scene Id"
          },
          "depth_map": {
            "$ref": "#/components/schemas/DepthMap"
          },
          "masks": {
            "items": {
              "$ref": "#/components/schemas/MaskResult"
            },
            "type": "array",
            "title": "Masks"
          },
          "metadata": {
            "$ref": "#/components/schemas/SceneMetadata"
          }
        },
        "type": "object",
        "required": ["scene_id", "depth_map", "masks", "metadata"],
        "title": "PreprocessResponse"
      },
      "SceneMetadata": {
        "properties": {
          "dominant_surface": {
            "type": "string",
            "title": "Dominant Surface"
          },
          "lighting_hint": {
            "type": "string",
            "title": "Lighting Hint"
          },
          "light_direction": {
            "type": "string",
            "title": "Light Direction"
          },
          "color_temperature": {
            "type": "string",
            "title": "Color Temperature"
          }
        },
        "type": "object",
        "required": ["dominant_surface", "lighting_hint", "light_direction", "color_temperature"],
        "title": "SceneMetadata"
      },
      "StyleHints": {
        "properties": {
          "prompt_suffix": {
            "type": "string",
            "title": "Prompt Suffix",
            "default": ""
          }
        },
        "type": "object",
        "title": "StyleHints"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      }
    }
  }
}
